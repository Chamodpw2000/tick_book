# Database
DATABASE_URL=

# Step Functions
STATE_MACHINE_ARN=
# AWS (local development)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""  # optional

# JSON body size (base64 images)
JSON_BODY_LIMIT="10mb"

# S3 (Event banner images)
S3_EVENT_BUCKET_NAME="your-event-banner-bucket"
BANNER_IMAGE_MAX_BYTES=5242880

# Optional overrides
# S3_EVENT_PUBLIC_BASE_URL="https://your-event-banner-bucket.s3.us-east-1.amazonaws.com"
# S3_ENDPOINT="http://localhost:4566"
# S3_FORCE_PATH_STYLE=true
