# Mongo
DATABASE_URL=

# Server
PORT=3004
JSON_BODY_LIMIT="10mb"  # must be large enough for base64 payloads

# AWS / S3 (Artist profile images)
AWS_REGION="us-east-1"
S3_ARTIST_BUCKET_NAME="your-artist-profile-bucket"

# Local development credentials (DO NOT commit real values)
# If you run on AWS with an IAM role, you typically don't need these.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""  # optional

# Optional (useful for LocalStack / MinIO)
# S3_ENDPOINT="http://localhost:4566"
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL="https://your-artist-profile-bucket.s3.us-east-1.amazonaws.com"

# Optional: only if your bucket allows ACLs (many buckets block ACLs)
# S3_OBJECT_ACL="public-read"

# Upload limits
PROFILE_IMAGE_MAX_BYTES=5242880
